# Supabase Postgres — ingestor writes predictions here (NOT the publishable key).
# Supabase Dashboard → Project Settings → Database → Connection string → URI
#
# NOTE: db.*.supabase.co is often IPv6-only. If you see "no route to host",
# either use the Session pooler URI from the dashboard, or rely on REST fallback
# by setting SUPABASE_SERVICE_ROLE_KEY (loaded from ../web/.env.local automatically).
#
# Direct connection (may require IPv6):
# DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.xgyfsmxorchkkxjaotda.supabase.co:5432/postgres
#
# Session pooler (recommended when direct connection fails):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# REST fallback (no DATABASE_URL needed if web/.env.local has service role key):
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_URL=https://xgyfsmxorchkkxjaotda.supabase.co
#
# Optional — omit GAME_PKS to auto-discover live games from MLB schedule
# GAME_PKS=823452,823368
# AUTO_DISCOVER_GAMES=true
# SCHEDULE_REFRESH_INTERVAL=5m
# POLL_INTERVAL=3s
